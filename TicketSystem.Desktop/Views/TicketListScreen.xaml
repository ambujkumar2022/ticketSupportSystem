<Window x:Class="TicketSystem.Desktop.Views.TicketListScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TicketSystem.Desktop.Views"
        mc:Ignorable="d"
        Title="Tickets" Height="400" Width="700">
    <DockPanel>

        <Button Content="Create Ticket" Click="Create_Click" DockPanel.Dock="Top"/>
        <Button Content="Refresh" Click="Refresh_Click" DockPanel.Dock="Top"/>

        <DataGrid x:Name="dgTickets" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}"/>
                <DataGridTextColumn Header="Subject" Binding="{Binding Subject}"/>
                <DataGridTextColumn Header="Priority" Binding="{Binding Priority}"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}"/>
                <DataGridTextColumn Header="Date" Binding="{Binding CreatedDate}"/>
                <DataGridTextColumn Header="Assigned To" Binding="{Binding AssignedTo}"/>

                <DataGridTemplateColumn Header="Action">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="View" Click="View_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
