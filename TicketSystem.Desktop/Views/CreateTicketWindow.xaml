<Window x:Class="TicketSystem.Desktop.Views.CreateTicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TicketSystem.Desktop.Views"
        mc:Ignorable="d"
        Title="Create Ticket" Height="500" Width="550">
    
    <StackPanel Margin="20">
        <TextBlock Text="Subject"/>
        <TextBox x:Name="txtSubject"/>

        <TextBlock Text="Description"/>
        <TextBox x:Name="txtDescription" Height="80" AcceptsReturn="True"/>

        <TextBlock Text="Priority"/>
        <ComboBox x:Name="cmbPriority">
            <ComboBoxItem Content="Low"/>
            <ComboBoxItem Content="Medium"/>
            <ComboBoxItem Content="High"/>
        </ComboBox>

        <Button Content="Submit" Click="Submit_Click" Margin="0,10"/>
    </StackPanel>
</Window>
